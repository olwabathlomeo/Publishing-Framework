<?xml version="1.0" encoding="UTF-8"?>

<publication>
  <common>
    <tableofcontents level="2" />
  </common>

  <source>
    <directories external="../assets" generated="../generated-assets" />
  </source>

  <html>
    <!-- Navigation sidebar with tree structure -->
    <navigation logic="tree" upbutton="yes" />
    <!-- Enable search bar -->
    <search variant="default" />
  </html>

  <pdf>
    <!-- Stylesheet for PDF -->
    <pages>
      <page type="frontmatter" />
      <page type="chapter" />
      <page type="backmatter" />
    </pages>
  </pdf>
</publication>
